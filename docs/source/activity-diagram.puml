@startuml
title Activity Diagram - ثبت‌نام با OTP (UC-01)
skinparam shadowing false
skinparam backgroundColor white

|کاربر|
start
:مراجعه به صفحه ثبت‌نام;
:وارد کردن شماره تلفن;

|سیستم|
:اعتبارسنجی شماره تلفن;

if (شماره معتبر است؟) then (بله)
  :بررسی عدم تکراری بودن شماره;

  if (شماره قبلاً ثبت شده است؟) then (بله)
    :نمایش پیام "شماره تکراری است";
    stop
  else (خیر)
    :تولید OTP ۵ رقمی;
    :ذخیره OTP با زمان انقضا ۵ دقیقه;
    :ارسال OTP از طریق پیامک;

    repeat
      |کاربر|
      :وارد کردن OTP;

      |سیستم|
      :اعتبارسنجی OTP;

      if (OTP صحیح است؟) then (بله)
        :ایجاد حساب کاربری;
        :ذخیره اطلاعات کاربر;
        :ایجاد نشست کاربر;
        :ارسال پیامک خوش‌آمدگویی;
        :نمایش پیام "ثبت‌نام موفق";
        |کاربر|
        :ورود به داشبورد;
        stop
      else (خیر)
        :ثبت تلاش ناموفق;

        if (تعداد تلاش ناموفق >= 5 ؟) then (بله)
          :قفل کردن حساب به مدت 15 دقیقه;
          :نمایش پیام "حساب موقتاً قفل شد";
          stop
        else (خیر)
          :نمایش پیام "کد اشتباه یا منقضی است";
        endif
      endif

    repeat while (OTP صحیح نیست و حساب قفل نشده است؟) is (بله)
  endif

else (خیر)
  :نمایش پیام "شماره تلفن نامعتبر است";
  stop
endif
@enduml

@startuml
title Activity Diagram - ثبت سفارش (UC-15)
skinparam shadowing false
skinparam backgroundColor white

|خریدار|
start
:باز کردن سبد خرید;
:بررسی آیتم‌های سبد;
:انتخاب دکمه "ثبت سفارش";

|سیستم|
:دریافت آیتم‌های سبد;
:بررسی اعتبار آیتم‌ها;
:بررسی موجودی هر آیتم;

if (همه آیتم‌ها معتبر و موجودی کافی است؟) then (بله)
  :محاسبه مبلغ نهایی;
  :فریز کردن قیمت واحد هر آیتم;
  :ایجاد رکورد سفارش با وضعیت "در انتظار تخصیص";
  :ذخیره آیتم‌ها در order_items;

  fork
    :کاهش موجودی محصولات;
  fork again
    :ثبت تاریخچه سفارش;
  fork again
    :ارسال پیامک تأیید سفارش;
  end fork

  :نمایش پیام "سفارش با موفقیت ثبت شد";

  |خریدار|
  :مشاهده سفارش در بخش "سفارش‌های من";
  stop

else (خیر)
  if (موجودی کافی نیست؟) then (بله)
    :نمایش پیام "موجودی کافی نیست";
    :مشخص کردن آیتم‌های کمبود;
    stop
  else (خیر)
    :نمایش پیام "یکی از آیتم‌ها نامعتبر است";
    stop
  endif
endif
@enduml

@startuml
title Activity Diagram - تخصیص سفارش به ویزیتور (UC-32)
skinparam shadowing false
skinparam backgroundColor white

|ادمین|
start
:ورود به پنل مدیریت;
:رفتن به بخش سفارش‌های در انتظار تخصیص;
:انتخاب یک سفارش;

|سیستم|
:نمایش لیست ویزیتورهای فعال;

|ادمین|
:انتخاب ویزیتور مناسب;
:تأیید تخصیص;

|سیستم|
:ثبت تخصیص در order_assignments;
:تغییر وضعیت سفارش به "تخصیص داده شده";
:ثبت تاریخچه وضعیت سفارش;

fork
  :ارسال پیامک به خریدار;
fork again
  :ارسال پیامک به ویزیتور;
end fork

:نمایش پیام "تخصیص با موفقیت انجام شد";

|ادمین|
if (نیاز به تغییر ویزیتور وجود دارد؟) then (بله)
  :انتخاب گزینه لغو تخصیص;
  |سیستم|
  :ثبت لغو تخصیص در تاریخچه;
  :بازگرداندن سفارش به وضعیت "در انتظار تخصیص";
  :نمایش لیست ویزیتورهای فعال;
  |ادمین|
  :انتخاب ویزیتور جدید;
  :تأیید تخصیص مجدد;
  |سیستم|
  :ثبت تخصیص جدید;
  :تغییر وضعیت به "تخصیص داده شده";
  fork
    :ارسال پیامک‌های جدید به خریدار;
  fork again
    :ارسال پیامک‌های جدید به ویزیتور;
  end fork
endif

stop
@enduml

@startuml
title Activity Diagram - تغییر وضعیت حمل توسط ویزیتور (UC-44 و UC-45)
skinparam shadowing false
skinparam backgroundColor white

|ویزیتور|
start
:ورود به پنل ویزیتور;
:مشاهده سفارش‌های تخصیص‌یافته;
:انتخاب یک سفارش;

|سیستم|
:نمایش جزئیات سفارش;

if (سفارش متعلق به همین ویزیتور و وضعیت آن "تخصیص داده شده" است؟) then (بله)

  |ویزیتور|
  :دریافت کالا از انبار;
  :انتخاب گزینه "بارگیری شد";

  |سیستم|
  :بررسی مجوز تغییر وضعیت;
  :تغییر وضعیت به "بارگیری شد";
  :ثبت تاریخچه وضعیت;
  :ارسال پیامک به خریدار;

  |ویزیتور|
  :تحویل کالا به خریدار;
  :انجام تسویه حضوری;
  :انتخاب گزینه "تحویل داده شد";

  |سیستم|
  :بررسی مجوز تغییر وضعیت;
  :تغییر وضعیت به "تحویل داده شد";
  :ثبت تاریخچه وضعیت;
  :ارسال پیامک نهایی به خریدار;
  :ارسال اعلان اتمام سفارش به ادمین;
  stop

else (خیر)
  :نمایش پیام "شما مجاز به انجام این عملیات نیستید";
  stop
endif
@enduml

@startuml
title Activity Diagram - ثبت محصول جدید توسط ادمین (UC-24)
skinparam shadowing false
skinparam backgroundColor white

|ادمین|
start
:ورود به پنل مدیریت;
:رفتن به بخش "ثبت محصول جدید";
:تکمیل فرم محصول;
:بارگذاری تصاویر محصول (حداکثر 5 تصویر);
:کلیک روی دکمه "ثبت";

|سیستم|
:اعتبارسنجی اطلاعات ورودی;

if (اطلاعات معتبر هستند؟) then (بله)
  :ذخیره تصاویر در فضای ذخیره‌سازی;
  :ایجاد رکورد محصول در دیتابیس;
  :ذخیره اطلاعات محصول;
  :ثبت تاریخچه اولیه محصول;

  if (موجودی > 0 ؟) then (بله)
    :فعال‌سازی نمایش محصول در اپلیکیشن;
    :نمایش پیام "محصول با موفقیت ثبت شد";
    stop
  else (خیر)
    :ثبت محصول با وضعیت "ناموجود";
    :نمایش پیام "محصول با موجودی صفر ثبت شد";
    stop
  endif

else (خیر)
  if (فیلدهای اجباری ناقص هستند؟) then (بله)
    :نمایش پیام "لطفاً تمام فیلدهای اجباری را تکمیل کنید";
  else (خیر)
    if (تصویر نامعتبر است؟) then (بله)
      :نمایش پیام "فرمت یا حجم تصویر نامعتبر است";
    else (خیر)
      :نمایش پیام "موجودی باید عدد معتبر باشد";
    endif
  endif
  stop
endif
@enduml
